      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Get cookies from response and store them",
          "const cookieJar = pm.cookies;",
          "const accessToken = cookieJar.get('access_token');",
          "const refreshToken = cookieJar.get('refresh_token');",
          "",
          "if (accessToken) {",
          "    pm.environment.set('access_token', accessToken);",
          "    console.log('🎫 Access token loaded');",
          "}",
          "",
          "if (refreshToken) {",
          "    pm.environment.set('refresh_token', refreshToken);",
          "}",
          "",
          "console.log('🚀 Running against MongoDB backend');"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Test for cache performance",
          "if (pm.response.code === 200) {",
          "    const responseTime = pm.response.responseTime;",
          "    console.log(`⏱️ Response time: ${responseTime}ms`);",
          "    ",
          "    // MongoDB ObjectId validation",
          "    const response = pm.response.json();",
          "    if (response && response.data && response.data.id) {",
          "        const id = response.data.id;",
          "        if (id && id.match(/^[0-9a-fA-F]{24}$/)) {",
          "            console.log('✅ Valid MongoDB ObjectId:', id);",
          "        }",
          "    }",
          "}"
        ]
      }
    }
  ]
