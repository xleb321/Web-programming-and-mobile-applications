	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Get cookies from response and store them",
					"const cookieJar = pm.cookies;",
					"const accessToken = cookieJar.get('access_token');",
					"const refreshToken = cookieJar.get('refresh_token');",
					"",
					"if (accessToken) {",
					"    pm.environment.set('access_token', accessToken);",
					"}",
					"",
					"if (refreshToken) {",
					"    pm.environment.set('refresh_token', refreshToken);",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Test for cache performance",
					"if (pm.response.code === 200) {",
					"    const responseTime = pm.response.responseTime;",
					"    console.log(`Response time: ${responseTime}ms`);",
					"    ",
					"    // Check if this is a cached response (indicated by header)",
					"    const xCache = pm.response.headers.get('X-Cache');",
					"    if (xCache === 'HIT') {",
					"        console.log('✅ Response from Redis Cache!');",
					"    } else {",
					"        console.log('📡 Response from Database');",
					"    }",
					"}"
				]
			}
		}
	]
