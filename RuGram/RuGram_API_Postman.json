        {
          "name": "Performance Comparison - Run Multiple Times",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseTime = pm.response.responseTime;",
                  "console.log(`📊 Request completed in ${responseTime}ms`);",
                  "",
                  "if (!pm.collectionVariables.get('avgTime')) {",
                  "    pm.collectionVariables.set('avgTime', responseTime);",
                  "    pm.collectionVariables.set('count', 1);",
                  "} else {",
                  "    const avg = (pm.collectionVariables.get('avgTime') * pm.collectionVariables.get('count') + responseTime) / (pm.collectionVariables.get('count') + 1);",
                  "    pm.collectionVariables.set('avgTime', avg);",
                  "    pm.collectionVariables.set('count', pm.collectionVariables.get('count') + 1);",
                  "    console.log(`📈 Average response time: ${Math.round(avg)}ms`);",
                  "}"
                ],
