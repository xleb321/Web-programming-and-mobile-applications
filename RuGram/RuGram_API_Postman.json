                  "    console.log('✅ FAST RESPONSE - Data served from Redis Cache!');",
                  "} else {",
                  "    console.log('⚠️ Response from MongoDB (Cache MISS)');",
                  "}",
                  "",
                  "pm.test('Response time should be fast (cached)', function() {",
                  "    pm.expect(responseTime).to.be.below(50);",
                  "});"
                ],
