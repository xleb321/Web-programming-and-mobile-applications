            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          },
          "response": []
        },
        {
          "name": "6️⃣ Logout All Sessions (Revokes All MongoDB Tokens & Redis Keys)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout-all",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout-all"]
            }
          },
          "response": []
        }
      ]
