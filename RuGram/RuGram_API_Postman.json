    {
      "name": "🔐 Authentication (MongoDB Users)",
      "item": [
        {
          "name": "1️⃣ Register New User (Creates MongoDB Document)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.id) {",
                  "        pm.environment.set('user_id', response.data.id);",
                  "        pm.environment.set('user_email', response.data.email);",
                  "        console.log('✅ User created with ID:', response.data.id);",
                  "        console.log('📝 MongoDB ObjectId:', response.data.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mongodb_user_{{$timestamp}}@example.com\",\n  \"password\": \"SecurePass123\",\n  \"phone\": \"+7{{$randomInt}}{{$randomInt}}{{$randomInt}}{{$randomInt}}{{$randomInt}}{{$randomInt}}{{$randomInt}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "2️⃣ Login (Creates Session in Redis & Token in MongoDB)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.user) {",
                  "        pm.environment.set('user_id', response.data.user.id);",
                  "        console.log('✅ Logged in as:', response.data.user.email);",
                  "        console.log('📝 MongoDB User ID:', response.data.user.id);",
                  "    }",
                  "    ",
                  "    // Get cookies",
                  "    const cookieJar = pm.cookies;",
                  "    const accessToken = cookieJar.get('access_token');",
                  "    if (accessToken) {",
                  "        console.log('🎫 Access token stored in cookie');",
                  "        console.log('🔑 JTI будет храниться в Redis для отзыва');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "3️⃣ Get Current User (Whoami) - From MongoDB",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/whoami",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "whoami"]
            }
          },
          "response": []
        },
        {
          "name": "4️⃣ Refresh Tokens (Creates New JTI in Redis)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
