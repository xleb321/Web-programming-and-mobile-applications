# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=rugram_user
DB_PASSWORD=rugram_password
DB_NAME=rugram_db

# Application
APP_PORT=4200
APP_ENV=development

# Pagination
DEFAULT_PAGE=1
DEFAULT_LIMIT=10
MAX_LIMIT=100

# JWT Secrets (change in production!)
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_change_in_prod
CACHE_TTL_DEFAULT=300

# Yandex OAuth
YANDEX_CLIENT_ID=ну_он_был_но_мы_его_прокакали
YANDEX_CLIENT_SECRET=ну_он_был_но_мы_его_прокакали
YANDEX_REDIRECT_URI=http://localhost:4200/api/v1/auth/oauth/yandex/callback

# VK OAuth
VK_CLIENT_ID=ну_и_его_тоже_прокакали
VK_CLIENT_SECRET=ну_и_его_тоже_прокакали
VK_REDIRECT_URI=http://localhost:4200/api/v1/auth/oauth/vk/callback